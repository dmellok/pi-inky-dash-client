# Inky Impression MQTT listener configuration.
# Copy this file to `.env` (or /etc/inky-mqtt/.env) and fill in your broker.

# --- Required ---
MQTT_BROKER=mqtt.local
MQTT_PORT=1883

# --- Optional auth ---
# Leave blank for an anonymous broker.
MQTT_USER=
MQTT_PASSWORD=

# --- Optional ---
MQTT_TOPIC=inky/update
MQTT_STATUS_TOPIC=inky/status
MQTT_CLIENT_ID=inky-impression
# Set to "true" to connect over TLS (port 8883 is typical).
MQTT_TLS=false

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
